# meeting-tui environment variables
# Copy to .env and fill in your values

# LLM Backend: ollama, openai, or gemini
# MEETING_TUI_LLM_BACKEND=ollama

# Ollama settings
# MEETING_TUI_OLLAMA_BASE_URL=http://localhost:11434
# MEETING_TUI_OLLAMA_MODEL=mistral

# OpenAI API (if using openai backend)
# OPENAI_API_KEY=sk-...

# Google Gemini API (if using gemini backend)
# GEMINI_API_KEY=...
# MEETING_TUI_GEMINI_MODEL=gemini-3-flash-preview

# Whisper model size: tiny, base, small, medium, large-v3
# MEETING_TUI_WHISPER_MODEL=base

# Audio device index (run `meeting-tui --list-devices` to see options)
# MEETING_TUI_AUDIO_DEVICE=0

# Output directory for transcripts
# MEETING_TUI_OUTPUT_DIR=~/meeting-transcripts
